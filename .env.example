# Local development defaults
DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,al-momindawakhana.store,www.al-momindawakhana.store
CSRF_TRUSTED_ORIGINS=https://al-momindawakhana.store,https://www.al-momindawakhana.store
USE_SQLITE=1

# Neon PostgreSQL. Use this instead of USE_SQLITE when testing PostgreSQL locally.
# Copy the pooled Neon connection string from neon.tech and keep sslmode=require.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
DB_SSL_REQUIRE=true

# Production example
# DEBUG=false
# ALLOWED_HOSTS=your-app.up.railway.app,al-momindawakhana.store,www.al-momindawakhana.store
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app,https://al-momindawakhana.store,https://www.al-momindawakhana.store